@model IEnumerable<AppLogic.DTOs.ClientDTO>

@{
    ViewData["Title"] = "Index";
}

<h1>Listado de clientes</h1>

@if (!string.IsNullOrEmpty(ViewBag.mensaje))
{
    <div class="alert alert-success">
        @ViewBag.mensaje
    </div>
}

<h2>Filtros</h2>


<div>
    <form method="post" action="/Client/FiltrarClientesNombre">
        <label for="palabra">Nombre: </label>
        <input type="type" name="palabra" id="palabra" />
        <input type="submit" />
    </form>
</div>

<div>
    <form method="post" action="/Client/FiltrarClientesApellido">
        <label for="palAp">Apellido: </label>
        <input type="type" name="palAp" id="palAp" />
        <input type="submit" />
    </form>
</div>

<div>
    <form method="post" action="/Client/FiltrarClientesPorMonto">
        <label for="monto">Monto: </label>
        <input type="number" name="monto" id="monto" />
        <input type="submit" />
    </form>
</div>

@* <p>
    <a asp-action="Create">Create New</a>
</p> *@

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.socialReason)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.rut)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.street)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.number)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.city)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.distance)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.surename)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.socialReason)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.rut)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.street)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.number)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.city)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.distance)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.surename)
                    </td>
                   @*  <td>
                        @* @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                        @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                        @Html.ActionLink("Delete", "Delete", new { /* id=item.PrimaryKey */ }) 
                    </td> *@
                </tr>
        }    
}
    </tbody>
</table>
